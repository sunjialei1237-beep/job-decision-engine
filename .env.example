# docker compose 自动读同目录 .env 注入容器环境。
# 用法:cp .env.example .env,然后填入你的值(切勿提交 .env)。

# LLM provider(必填)
BASE_URL=https://open.bigmodel.cn/api/anthropic
API_KEY=your-key-here
MODEL=glm-5.2

# 可选
# PROTOCOL=anthropic        # base_url 含 /anthropic 时自动推断,通常无需设
# RATE_LIMIT_PER_MINUTE=20  # 限流窗口容量
# ENGINE_API_KEYS=k1,k2     # 生产必配:逗号分隔的合法 key,开启 API key 认证(未配=开发放行)
